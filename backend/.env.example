# ─── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Use MongoDB Atlas string for production deployment
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/mern_app?retryWrites=true&w=majority

# ─── Security & Authentication ───────────────────────────────────────────────
# Generate a strong, random string for JWT_SECRET in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── CORS Configuration ──────────────────────────────────────────────────────
# Point this to your Vercel frontend URL in production
CLIENT_URL=http://localhost:5173
