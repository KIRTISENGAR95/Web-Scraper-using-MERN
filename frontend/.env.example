# ─── Vite Environment Variables ───────────────────────────────────────────────

# The URL of your backend API. 
# During local development, this usually points to localhost:5000/api.
# Once deployed, change this in your Vercel Dashboard settings to point to your Render URL.
# Example Production: VITE_API_URL=https://my-backend.onrender.com/api

VITE_API_URL=http://localhost:5000/api
